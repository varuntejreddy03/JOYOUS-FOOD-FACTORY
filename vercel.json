{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(assets|1|2|3|4|5|Combo)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31104000, immutable"
        }
      ]
    }
  ]
}
